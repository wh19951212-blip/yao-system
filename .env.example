# ============================================================
# YAO 投资管理系统 — 环境变量配置
# 复制本文件为 .env 并填入真实值，然后重启 npm run dev
# ============================================================

# ---------- Supabase（必填）----------
# Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ---------- Claude AI（可选，启用 AI 功能时需要）----------
# 模型：claude-sonnet-4-20250514
# 申请地址：https://console.anthropic.com
#
# 方式 A（推荐生产部署）：浏览器直接调用
VITE_ANTHROPIC_API_KEY=your-anthropic-api-key
#
# 方式 B（仅本地开发）：Vite 代理，密钥不暴露到浏览器
# 留空 VITE_ANTHROPIC_API_KEY，仅配置下方变量
ANTHROPIC_API_KEY=your-anthropic-api-key

# ============================================================
# 部署前请在 Supabase SQL Editor 执行：
#   supabase/schema.sql        — 完整建表（新项目）
#   supabase/fix_permissions.sql — 已有项目补权限/新表
#
# 所需 Storage Buckets（Dashboard > Storage 创建）：
#   - property-images（公开）
#   - contract-files（公开）
#   - media-assets（公开）
#
# 主要数据表：
#   investors, follow_up_logs, lands, land_approval_nodes,
#   builder_quotes, properties, investor_property_matches,
#   buyers, builders, hotels, contracts, media_assets,
#   users, app_settings, investor_stage_logs, operation_logs
# ============================================================

# ---------- 构建与部署命令 ----------
# npm install
# npm run build
# npm run preview   # 本地预览生产包
#
# 静态部署：将 dist/ 目录上传至 Vercel / Netlify / Cloudflare Pages
# 环境变量在部署平台配置（与上方 VITE_ 前缀变量相同）
